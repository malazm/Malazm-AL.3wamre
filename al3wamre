<script>
// ===== BACKGROUND GENERATOR =====
const scenes = [
  // Sunrise forest
  { sky: ['#ff9a3c','#ffca66','#87ceeb'], ground: '#2d5a1b', elements: 'forest', label: 'غابة عند الشروق' },
  // Ocean at dusk
  { sky: ['#2c3e7a','#7b4fa0','#e8836a'], ground: '#1a4a6b', elements: 'ocean', label: 'محيط عند الغروب' },
  // Mountain snow
  { sky: ['#c9e8f5','#e8f4f8','#f0f8ff'], ground: '#6b9ab8', elements: 'mountains', label: 'جبال ثلجية' },
  // Desert sunset
  { sky: ['#ff6b35','#f7c59f','#ffe0b2'], ground: '#c8913a', elements: 'desert', label: 'صحراء عند الغروب' },
  // Night stars
  { sky: ['#0a0a2e','#1a1a4e','#0d1b3e'], ground: '#1a3a1a', elements: 'night', label: 'ليل مرصّع بالنجوم' },
  // Spring meadow
  { sky: ['#87ceeb','#b8e0f7','#dff2ff'], ground: '#4a8c2a', elements: 'meadow', label: 'مرج ربيعي' },
];

let currentScene = -1;
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');

function resizeCanvas() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}

function drawBackground() {
  currentScene = (currentScene + 1) % scenes.length;
  const scene = scenes[currentScene];
  resizeCanvas();
  const w = canvas.width, h = canvas.height;

  // Sky gradient
  const sky = ctx.createLinearGradient(0, 0, 0, h * 0.7);
  scene.sky.forEach((c, i) => sky.addColorStop(i / (scene.sky.length - 1), c));
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, w, h);

  const e = scene.elements;

  if (e === 'forest') {
    // Ground
    ctx.fillStyle = '#2d5a1b';
    ctx.fillRect(0, h * 0.7, w, h * 0.3);
    // Trees
    for (let i = 0; i < 18; i++) {
      const x = (w / 18) * i + (w / 36);
      const th = h * 0.15 + Math.random() * h * 0.2;
      const tx = x + (Math.random() - 0.5) * 40;
      ctx.fillStyle = `hsl(${120 + Math.random() * 30},${40 + Math.random() * 30}%,${20 + Math.random() * 20}%)`;
      ctx.beginPath();
      ctx.moveTo(tx, h * 0.7 - th);
      ctx.lineTo(tx - th * 0.35, h * 0.7);
      ctx.lineTo(tx + th * 0.35, h * 0.7);
      ctx.fill();
    }
    // Sun
    const grad = ctx.createRadialGradient(w * 0.8, h * 0.15, 0, w * 0.8, h * 0.15, 60);
    grad.addColorStop(0, 'rgba(255,220,80,0.95)');
    grad.addColorStop(1, 'rgba(255,150,50,0)');
    ctx.fillStyle = grad;
    ctx.beginPath(); ctx.arc(w * 0.8, h * 0.15, 60, 0, Math.PI * 2); ctx.fill();
  } else if (e === 'ocean') {
    // Water
    const water = ctx.createLinearGradient(0, h * 0.6, 0, h);
    water.addColorStop(0, '#1a4a8b'); water.addColorStop(1, '#0a1f3a');
    ctx.fillStyle = water;
    ctx.fillRect(0, h * 0.6, w, h * 0.4);
    // Waves
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.lineWidth = 2;
    for (let i = 0; i < 5; i++) {
      const y = h * 0.65 + i * h * 0.06;
      ctx.beginPath();
      for (let x = 0; x < w; x += 5) {
        ctx.lineTo(x, y + Math.sin(x * 0.02 + i) * 8);
      }
      ctx.stroke();
    }
    // Moon
    ctx.fillStyle = 'rgba(255,240,200,0.9)';
    ctx.beginPath(); ctx.arc(w * 0.3, h * 0.2, 35, 0, Math.PI * 2); ctx.fill();
  } else if (e === 'mountains') {
    // Snow peaks
    const ranges = [[0.1,0.6,0.3], [0.35,0.55,0.25], [0.6,0.65,0.35], [0.85,0.6,0.3]];
    ranges.forEach(([cx, base, size], i) => {
      ctx.fillStyle = `hsl(200,${15+i*5}%,${50+i*5}%)`;
      ctx.beginPath();
      ctx.moveTo(w * cx, h * (base - size));
      ctx.lineTo(w * (cx - size * 0.7), h * base);
      ctx.lineTo(w * (cx + size * 0.7), h * base);
      ctx.fill();
      // Snow cap
      ctx.fillStyle = '#eef5ff';
      ctx.beginPath();
      ctx.moveTo(w * cx, h * (base - size));
      ctx.lineTo(w * (cx - size * 0.15), h * (base - size * 0.7));
      ctx.lineTo(w * (cx + size * 0.15), h * (base - size * 0.7));
      ctx.fill();
    });
    ctx.fillStyle = '#4a7a9b';
    ctx.fillRect(0, h * 0.65, w, h * 0.35);
  } else if (e === 'desert') {
    // Sand dunes
    ctx.fillStyle = '#d4a853';
    ctx.fillRect(0, h * 0.6, w, h * 0.4);
    for (let i = 0; i < 4; i++) {
      ctx.fillStyle = `hsl(38,${50+i*8}%,${50+i*6}%)`;
      ctx.beginPath();
      ctx.moveTo(w * (i * 0.3), h);
      ctx.quadraticCurveTo(w * (i * 0.3 + 0.15), h * 0.55, w * (i * 0.3 + 0.3), h);
      ctx.fill();
    }
    // Cactus silhouettes
    for (let i = 0; i < 3; i++) {
      const cx = w * (0.15 + i * 0.35);
      ctx.fillStyle = '#1a4a1a';
      ctx.fillRect(cx - 6, h * 0.45, 12, h * 0.2);
      ctx.fillRect(cx - 20, h * 0.52, 14, 8);
      ctx.fillRect(cx + 6, h * 0.55, 14, 8);
    }
  } else if (e === 'night') {
    // Stars
    for (let i = 0; i < 200; i++) {
      const x = Math.random() * w, y = Math.random() * h * 0.75;
      const r = Math.random() * 1.5;
      ctx.fillStyle = `rgba(255,255,240,${0.4 + Math.random() * 0.6})`;
      ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2); ctx.fill();
    }
    // Moon crescent
    ctx.fillStyle = 'rgba(255,245,210,0.95)';
    ctx.beginPath(); ctx.arc(w * 0.75, h * 0.18, 40, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = scene.sky[0];
    ctx.beginPath(); ctx.arc(w * 0.75 + 20, h * 0.18 - 8, 34, 0, Math.PI * 2); ctx.fill();
    // Ground/trees silhouette
    ctx.fillStyle = '#0a1a0a';
    ctx.fillRect(0, h * 0.75, w, h * 0.25);
    for (let i = 0; i < 12; i++) {
      const tx = (w / 12) * i + w / 24;
      const th = h * 0.1 + Math.random() * h * 0.15;
      ctx.beginPath();
      ctx.moveTo(tx, h * 0.75 - th);
      ctx.lineTo(tx - th * 0.3, h * 0.75);
      ctx.lineTo(tx + th * 0.3, h * 0.75);
      ctx.fill();
    }
  } else if (e === 'meadow') {
    // Ground
    ctx.fillStyle = '#5cad2f';
    ctx.fillRect(0, h * 0.65, w, h * 0.35);
    // Flowers
    for (let i = 0; i < 60; i++) {
      const fx = Math.random() * w, fy = h * 0.65 + Math.random() * h * 0.3;
      const colors = ['#ff6b9d','#ffb347','#fff176','#f48fb1','#ce93d8'];
      ctx.fillStyle = colors[Math.floor(Math.random() * colors.length)];
      ctx.beginPath(); ctx.arc(fx, fy, 4 + Math.random() * 5, 0, Math.PI * 2); ctx.fill();
    }
    // Sun
    const grad2 = ctx.createRadialGradient(w * 0.5, h * 0.1, 0, w * 0.5, h * 0.1, 70);
    grad2.addColorStop(0, 'rgba(255,230,80,1)');
    grad2.addColorStop(1, 'rgba(255,180,50,0)');
    ctx.fillStyle = grad2;
    ctx.beginPath(); ctx.arc(w * 0.5, h * 0.1, 70, 0, Math.PI * 2); ctx.fill();
    // Clouds
    for (let i = 0; i < 4; i++) {
      const cx = w * (0.1 + i * 0.25), cy = h * (0.25 + i * 0.05);
      ctx.fillStyle = 'rgba(255,255,255,0.85)';
      for (let j = 0; j < 4; j++) {
        ctx.beginPath(); ctx.arc(cx + j * 22 - 30, cy, 22 - Math.abs(j - 1.5) * 4, 0, Math.PI * 2); ctx.fill();
      }
    }
  }

  canvas.style.animation = 'bgFade 0.8s ease';
  setTimeout(() => canvas.style.animation = '', 800);
}

// ===== WELCOME MODAL =====
function openSite() {
  document.getElementById('welcomeModal').style.display = 'none';
  document.getElementById('mainContent').classList.add('visible');
}

// ===== DOWNLOAD MODAL =====
let timerInterval = null;

function startDownload(url) {
  const modal = document.getElementById('dlModal');
  const circle = document.getElementById('timerCircle');
  const link = document.getElementById('dlLink');
  
  link.href = url;
  link.classList.remove('ready');
  circle.textContent = '5';
  modal.classList.add('active');

  let count = 5;
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    count--;
    circle.textContent = count;
    if (count <= 0) {
      clearInterval(timerInterval);
      circle.textContent = '✓';
      circle.style.borderColor = '#27ae60';
      link.classList.add('ready');
    }
  }, 1000);
}

function closeDlModal() {
  clearInterval(timerInterval);
  document.getElementById('dlModal').classList.remove('active');
  document.getElementById('timerCircle').style.borderColor = 'var(--accent)';
}

// ===== INIT =====
window.addEventListener('resize', () => { resizeCanvas(); drawBackground(); });
drawBackground(); // initial background
