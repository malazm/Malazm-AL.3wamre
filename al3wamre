<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ملازم الأحياء</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --accent: #2ecc71;
    --accent2: #27ae60;
    --red: #e74c3c;
    --dark: rgba(0,0,0,0.55);
    --glass: rgba(255,255,255,0.13);
    --glass-border: rgba(255,255,255,0.25);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Tajawal', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Dynamic AI background */
  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    transition: opacity 0.8s ease;
  }

  /* Overlay */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.38);
    z-index: -1;
  }

  /* MODAL */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.4s ease;
  }

  .modal {
    background: rgba(10,20,15,0.92);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    padding: 40px 36px;
    max-width: 520px;
    width: 90%;
    text-align: center;
    color: #fff;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(46,204,113,0.2);
    animation: slideUp 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }

  .modal .bismillah {
    font-size: 2rem;
    color: var(--accent);
    margin-bottom: 20px;
    text-shadow: 0 0 20px rgba(46,204,113,0.5);
  }

  .modal p {
    font-size: 1rem;
    line-height: 1.9;
    color: rgba(255,255,255,0.88);
    margin-bottom: 28px;
  }

  .modal-btn {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff;
    border: none;
    padding: 14px 48px;
    border-radius: 50px;
    font-family: 'Tajawal', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(46,204,113,0.4);
  }

  .modal-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(46,204,113,0.5);
  }

  /* MAIN CONTENT */
  .main {
    display: none;
    min-height: 100vh;
    padding: 40px 20px 60px;
  }

  .main.visible { display: block; animation: fadeIn 0.6s ease; }

  header {
    text-align: center;
    margin-bottom: 48px;
  }

  header h1 {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
    letter-spacing: -0.5px;
  }

  header h1 span { color: var(--accent); }

  header p {
    color: rgba(255,255,255,0.7);
    margin-top: 8px;
    font-size: 1rem;
  }

  /* CARDS GRID */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    max-width: 960px;
    margin: 0 auto;
  }

  .card {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 24px;
    backdrop-filter: blur(12px);
    color: #fff;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .btn-group {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .btn {
    flex: 1;
    min-width: 90px;
    padding: 10px 16px;
    border: none;
    border-radius: 10px;
    font-family: 'Tajawal', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .btn-view {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .btn-view:hover {
    background: rgba(255,255,255,0.25);
  }

  .btn-download {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff;
    box-shadow: 0 4px 14px rgba(46,204,113,0.3);
  }

  .btn-download:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 20px rgba(46,204,113,0.5);
  }

  .btn-whatsapp {
    background: linear-gradient(135deg, #e74c3c, #c0392b);
    color: #fff;
    box-shadow: 0 4px 14px rgba(231,76,60,0.3);
    width: 100%;
  }

  .btn-whatsapp:hover {
    transform: scale(1.03);
    box-shadow: 0 6px 20px rgba(231,76,60,0.5);
  }

  /* DOWNLOAD MODAL */
  .dl-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(6px);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .dl-modal-backdrop.active { display: flex; animation: fadeIn 0.3s ease; }

  .dl-modal {
    background: rgba(10,25,18,0.95);
    border: 1px solid rgba(46,204,113,0.3);
    border-radius: 18px;
    padding: 36px;
    max-width: 380px;
    width: 88%;
    text-align: center;
    color: #fff;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    animation: slideUp 0.4s ease;
  }

  .timer-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 4px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent);
    margin: 0 auto 20px;
    box-shadow: 0 0 20px rgba(46,204,113,0.3);
    transition: all 0.3s;
  }

  .salah-text {
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 8px;
    font-weight: 700;
  }

  .salah-sub {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 20px;
  }

  .dl-link {
    display: inline-block;
    margin-top: 10px;
    padding: 12px 30px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.2s;
    opacity: 0;
    pointer-events: none;
  }

  .dl-link.ready {
    opacity: 1;
    pointer-events: all;
    animation: pulse 1.5s infinite;
  }

  .close-dl {
    position: absolute;
    top: 12px;
    left: 16px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 1.4rem;
    cursor: pointer;
  }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 30px 20px;
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    font-weight: 700;
    text-shadow: 0 1px 10px rgba(0,0,0,0.5);
    letter-spacing: 1px;
  }

  /* ANIMATIONS */
  @keyframes fadeIn { from { opacity: 0 } to { opacity: 1 } }
  @keyframes slideUp {
    from { transform: translateY(40px); opacity: 0 }
    to { transform: translateY(0); opacity: 1 }
  }
  @keyframes pulse {
    0%,100% { box-shadow: 0 4px 14px rgba(46,204,113,0.3) }
    50% { box-shadow: 0 4px 28px rgba(46,204,113,0.7) }
  }
  @keyframes bgFade {
    from { opacity: 0 }
    to { opacity: 1 }
  }
</style>
